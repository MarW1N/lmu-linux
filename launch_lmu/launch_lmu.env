# Environment variables for launch_lmu.sh. Modify these as needed to configure the behavior of the script and the tools it launches.

# LMU Bridge and LMUFFB are optional tools that can be launched alongside the game. Set the following variables to true to enable them, or false to disable them.
# Github repo at https://github.com/Spacefreak18/simshmbridge
# If declared, should be a directory containing lmubridge.exe and lmushm from
#SIMSHMBRIDGE_DIR="${HOME}/Apps/simshmbridge"

# LMUFFB is a force feedback enhancement tool
# Github repo at https://github.com/coasting-nc/LMUFFB
# PATH to LMUFFB, this should be the directory containing LMUFFB.exe
# If not-empty, LMUFFB will be launched with the game.
#LMUFFB_DIR="${HOME}/Apps/LMUFFB"

# Set this to true to enable debug logging to launch_lmu.log, or false to disable it.
#DEBUG=true

######################################################################################################
# Proton and DXVK environment variables for LMU. Feel free to modify or comment out these as needed. #
######################################################################################################

# Disable forced full-screen anti-aliasing
#__GL_FSAA_MODE=0

# Set the maximum anisotropic filtering level to 16 (4^2). This can improve performance in some games, but may cause issues on older hardware.
#__GL_LOG_MAX_ANISO=4

# Enable the OpenGL shader disk cache to improve performance by caching compiled shaders on disk. This can reduce stuttering in games that compile shaders at runtime, but may cause issues if the cache becomes corrupted.
#__GL_SHADER_DISK_CACHE=1

# Prevent the OpenGL shader disk cache from being automatically cleared. This can help maintain performance over time, but may cause issues if the cache becomes corrupted or takes up too much disk space.
#__GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1

# Enable Wayland support in Proton. This can improve performance and compatibility on Wayland sessions, but may cause issues on some systems.
#PROTON_ENABLE_WAYLAND=1

# Enable NTSYNC support in Proton. This is a newer synchronization method that can improve performance and reduce stuttering in some games, but may cause issues on older titles or certain hardware.
#PROTON_USE_NTSYNC=1

# Disables Eventfd Synchronization. Like Fsync, turning this off reduces overall performance but can fix crashes in older games that spawn many windows or threads.
#PROTON_NO_ESYNC=1

# Disables Futex Synchronization. Fsync is used by default to improve CPU performance, but turning it off can resolve freezing or stuttering issues in specific titles.
#PROTON_NO_FSYNC=1

# Enable NVAPI support to enable advanced nVidia features like DLSS and Reflex. This may cause issues on some systems, so only enable if you know you need it.
#PROTON_ENABLE_NVAPI=1

# Enable asynchronous shader compilation in DXVK. This can improve performance, but may cause stuttering during shader compilation.
#DXVK_ASYNC=1

# Enable the DXVK HUD to display FPS and shader compilation status. This can be useful for troubleshooting performance issues, but may cause a slight performance hit.
#DXVK_HUD=fps,compiler
