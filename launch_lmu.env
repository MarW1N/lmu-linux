# Path to simshmbridge, this should be the directory containing lmubridge.exe and lmushm
SIMSHMBRIDGE_PATH="${HOME}/Apps/simshmbridge/bin"

# Proton and DXVK environment variables for LMU. Feel free to modify or comment out these as needed.
__GL_FSAA_MODE=0
__GL_LOG_MAX_ANISO=4
__GL_SHADER_DISK_CACHE=1
__GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1
DXVK_ASYNC=1
PROTON_ENABLE_WAYLAND=1
PROTON_NO_ESYNC=1
PROTON_NO_FSYNC=1
PROTON_ENABLE_NVAPI=1
